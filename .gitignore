# --- VPS disaster-recovery backup: whitelist runtime data files ---
# Keep bulk data ignored by default, but track the files the dashboard imports.
!data/raw/.gitkeep
!data/processed/.gitkeep
# Re-include the processed/ directory itself so per-file !rules below take effect.
!data/processed/

!data/raw/matches_2026.json
!data/raw/elo_ratings.json
